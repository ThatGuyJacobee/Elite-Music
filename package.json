{
  "name": "elite-bot-music",
  "version": "1.0.0",
  "description": "Elite Bot's original music feature moved to a separate discord bot.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --watch \"**/*.ts\" --exec \"ts-node\" index.ts",
    "start": "node dist/index.js",
    "prettier": "prettier \"index.ts\" \"{commands,events,utils,types}/**/*.{ts,css,md,mdx,json}\" --check",
    "prettier:write": "prettier \"index.ts\" \"{commands,events,utils,types}/**/*.{ts,css,md,mdx,json}\" --write",
    "docker:latest": "node scripts/docker-build.js --latest",
    "docker:build": "node scripts/docker-build.js"
  },
  "author": "ThatGuyJacobee",
  "license": "ISC",
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "2.6.1",
    "@snazzah/davey": "^0.1.12",
    "bgutils-js": "^3.2.0",
    "discord-api-types": "^0.38.49",
    "discord-player": "^7.2.0",
    "discord-player-youtubei": "^2.0.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "5.3.0",
    "ms": "2.1.3",
    "sodium-native": "^5.1.0",
    "youtube-dl-exec": "^3.1.8"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^22.10.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
