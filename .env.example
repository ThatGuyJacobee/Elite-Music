# DO NOT TOUCH - THIS CHECKS AGAINST CONFIG VERSIONING/UPDATES
CFG_VERSION=1.9
VERBOSE='none' # Provide verbose logging to the console: none, normal, full
DOCKER_IMAGE_REPO='thatguyjacobee/elitemusic' # Docker Hub repo: used only for the docker image build script

# CONFIGURATION SETTINGS
TOKEN='DISCORD_BOT_TOKEN'
YT_CREDENTIALS='' # Optional, improves YT stability (see guide)

# GENERAL SETTINGS
EMBED_COLOUR='#FF0000'
PRESENCE='/help | elite-bot.com'

# TRANSLATION/LOCALE SETTINGS
PRIMARY_LOCALE='en-GB' # Primary locale for the bot (see /locales folder for available languages)
LOCALE_MODE='user' # Locale mode: user (localise via Discord client locale where possible, fallback to primary) or global (always use primary locale)

# MUSIC PLAYBACK BEHAVIOUR SETTINGS
LEAVE_ON_EMPTY=true
LEAVE_ON_EMPTY_COOLDOWN=300000

LEAVE_ON_END=true
LEAVE_ON_END_COOLDOWN=300000

LEAVE_ON_STOP=true
LEAVE_ON_STOP_COOLDOWN=300000

SELF_DEAFEN=true
DEFAULT_VOLUME=50
SMOOTH_VOLUME=true

### ADDITIONAL FEATURES SETTINGS

# DJ MODE SETTINGS
ENABLE_DJMODE=false
DJ_ROLE=123456789987654321

# PLEX MEDIA SERVER SETTINGS
ENABLE_PLEX=false
PLEX_SERVER='http://YOUR_IPADDRESS:32400'
PLEX_AUTHTOKEN='YOUR_AUTH_TOKEN'

# SUBSONIC MEDIA SERVER SETTINGS
ENABLE_SUBSONIC=false
SUBSONIC_SERVER='http://YOUR_IPADDRESS:4533'
SUBSONIC_USER='YOUR_USERNAME'
SUBSONIC_PASS='YOUR_PASSWORD'
SUBSONIC_APP_NAME='Elite-Music-Bot'